# =============================================================
#  HA SSO (microk8s) — centralna konfiguracija
#  Sve vrijednosti specifične za instituciju mijenjaju se OVDJE.
# =============================================================

# --- Čvorovi klastera -----------------------------------------
# Prvi čvor je inicijalni; ostali mu se pridružuju.
NODE0_IP="78.28.135.130"
NODE1_IP="78.28.135.131"
NODE2_IP="78.28.135.132"

NODE0_NAME="n00"
NODE1_NAME="n01"
NODE2_NAME="n02"

# --- microk8s -------------------------------------------------
# Kanal određuje verziju Kubernetesa koju microk8s instalira.
MICROK8S_CHANNEL="1.29/stable"

# --- Domen i TLS ---------------------------------------------
# Javni hostname preko kojeg se pristupa Keycloaku.
# Mora imati DNS A-zapis koji pokazuje na (jedan od) čvorova
# ili na javnu IP adresu Ingressa.
KEYCLOAK_HOSTNAME="auth.etfbl.net"
ORG_NAME="Univerzitet u Banjoj Luci"
ORG_TLS_O="ETF Banja Luka"

# --- Keycloak -------------------------------------------------
KEYCLOAK_INSTANCES="3"
KEYCLOAK_ADMIN_USER="admin"
# Lozinke se NE čuvaju ovdje. Prosljeđuju se skripti 04-secrets.sh
# kao argumenti ili kroz env varijable.

# --- PostgreSQL (CloudNativePG) -------------------------------
PG_INSTANCES="3"
PG_STORAGE_SIZE="20Gi"
# Naziv storage klase. Za microk8s sa uključenim 'hostpath-storage'
# dodatkom ostavite prazno (koristi se podrazumijevana klasa).
PG_STORAGE_CLASS=""
PG_DATABASE="keycloak"
PG_USERNAME="keycloak"

# --- Realm ----------------------------------------------------
REALM_NAME="unibl"
REALM_DISPLAY_NAME="Univerzitet u Banjoj Luci"

# --- Namespace ------------------------------------------------
NAMESPACE="keycloak"

# --- Verzije operatora ----------------------------------------
CNPG_VERSION="1.23.0"
CNPG_RELEASE_BRANCH="release-1.23"
KEYCLOAK_VERSION="26.6.4"
